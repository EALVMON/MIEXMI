<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:paddingHorizontal="4dp"
        android:baselineAligned="false">

        <TextView
            android:id="@+id/tvItemNombreIdioma"
            style="@style/EstiloTextoColumna"
            android:layout_weight="1.5"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Inglés" />

        <TextView
            android:id="@+id/tvItemResultadoSlp"
            style="@style/EstiloItemSecundario"
            android:layout_weight="1"
            tools:text="2.2.2+.2" />

        <TextView
            android:id="@+id/tvItemFechaIdioma"
            style="@style/EstiloItemSecundario"
            android:layout_weight="1"
            tools:text="10/05/2023" />

        <TextView
            android:id="@+id/tvItemBodIdioma"
            style="@style/EstiloItemSecundario"
            android:layout_weight="0.8"
            android:textAlignment="viewEnd"
            tools:text="95" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/blanco_lista" />
</LinearLayout>