<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gris_fondo_abajo">

    <View
        android:id="@+id/viewHeaderLog"
        style="@style/EstiloCabeceraAzul"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnVolverLog"
        style="@style/EstiloBotonVolver"
        android:contentDescription="@string/volver"
        android:src="@drawable/abc_ic_ab_back_material"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTituloLog"
        style="@style/EstiloTituloPantalla"
        android:text="@string/titulo_registro_actividad"
        app:layout_constraintBottom_toBottomOf="@+id/btnVolverLog"
        app:layout_constraintStart_toEndOf="@+id/btnVolverLog"
        app:layout_constraintTop_toTopOf="@+id/btnVolverLog" />

    <LinearLayout
        android:id="@+id/layoutTitulosLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        android:orientation="horizontal"
        android:baselineAligned="false"
        app:layout_constraintTop_toBottomOf="@+id/viewHeaderLog">

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="0.4"
            android:text="@string/nº" />

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="1.2"
            android:text="@string/dni_log" />

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="1.5"
            android:text="@string/fecha_hora_log"
            android:textAlignment="viewEnd" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLogActividad"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutTitulosLog"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:listitem="@layout/item_log_actividad" />

</androidx.constraintlayout.widget.ConstraintLayout>