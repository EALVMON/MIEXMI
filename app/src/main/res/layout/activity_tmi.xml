<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gris_fondo_abajo">

    <View
        android:id="@+id/viewHeaderTmi"
        style="@style/EstiloCabeceraAzul"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnVolverTmi"
        style="@style/EstiloBotonVolver"
        android:contentDescription="@string/volver"
        android:src="@drawable/abc_ic_ab_back_material"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTituloTmi"
        style="@style/EstiloTituloPantalla"
        android:text="@string/tmi_pantalla"
        app:layout_constraintBottom_toBottomOf="@+id/btnVolverTmi"
        app:layout_constraintStart_toEndOf="@+id/btnVolverTmi"
        app:layout_constraintTop_toTopOf="@+id/btnVolverTmi" />

    <LinearLayout
        android:id="@+id/layoutFormularioInferiorTmi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@color/blanco_insercion"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/numero_tarjeta_tmi"
            app:boxStrokeColor="@color/bbva_blue">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNumeroTmi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapCharacters" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/fecha_caducidad_tmi"
            app:boxStrokeColor="@color/bbva_blue">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFechaCaducidadTmi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAnadirTmi"
                style="@style/EstiloBotonAnadir"
                android:text="@string/anadir" />

            <Button
                android:id="@+id/btnModificarTmi"
                style="@style/EstiloBotonEditar"
                android:text="@string/editar" />

            <Button
                android:id="@+id/btnEliminarTmi"
                style="@style/EstiloBotonBorrar"
                android:text="@string/borrar" />

            <Button
                android:id="@+id/btnLimpiarTmi"
                style="@style/EstiloBotonLimpiar"
                android:text="@string/limpiar" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTituloListaTmi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/historial_tmi_guardadas"
        android:textColor="@color/bbva_blue"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/viewHeaderTmi" />

    <LinearLayout
        android:id="@+id/layoutTitulosColumnasTmi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        android:orientation="horizontal"
        android:baselineAligned="false"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloListaTmi">

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="0.5"
            android:text="@string/nº"/>

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="2.5"
            android:text="@string/numero_tarjeta_tmi"/>

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="1.5"
            android:text="@string/fecha_caducidad_tmi"
            android:textAlignment="viewEnd"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTmi"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutTitulosColumnasTmi"
        app:layout_constraintBottom_toTopOf="@+id/layoutFormularioInferiorTmi"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:listitem="@layout/item_tmi" />

</androidx.constraintlayout.widget.ConstraintLayout>