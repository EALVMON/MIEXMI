<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:paddingHorizontal="4dp"
        android:baselineAligned="false">

        <TextView
            android:id="@+id/tvItemNombreHps"
            style="@style/EstiloTextoColumna"
            android:layout_weight="2"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Habilitación Confidencial" />

        <TextView
            android:id="@+id/tvItemConcesionHps"
            style="@style/EstiloItemSecundario"
            android:layout_weight="1"
            tools:text="10/01/2022" />

        <TextView
            android:id="@+id/tvItemCaducidadHps"
            style="@style/EstiloItemSecundario"
            android:layout_weight="1"
            android:textAlignment="viewEnd"
            tools:ignore="VisualLintSystemNav"
            tools:text="10/01/2027" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/blanco_lista" />

</LinearLayout>