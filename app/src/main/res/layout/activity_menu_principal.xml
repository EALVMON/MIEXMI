<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F7">

    <View
        android:id="@+id/viewHeader"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:background="#004481"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBienvenida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:text="Bienvenido,"
        android:textColor="#CCFFFFFF"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvNombreMilitar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Eduardo Álvarez"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/tvBienvenida"
        app:layout_constraintTop_toBottomOf="@+id/tvBienvenida" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardResumen"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/viewHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/viewHeader">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTituloResumen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumen del Expediente"
                android:textColor="#004481"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvDetalleEmpleo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Empleo: Sargento Primero"
                android:textColor="#444444"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvTituloResumen" />

            <TextView
                android:id="@+id/tvDetalleDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Destino: CIFP Avilés (PMDM)"
                android:textColor="#444444"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvDetalleEmpleo" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardResumen">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardDatosPersonales"
                style="@style/EstiloModuloCard">
                <TextView style="@style/EstiloModuloTexto" android:text="Datos\nPersonales" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardHistorialProfesional"
                style="@style/EstiloModuloCard">
                <TextView style="@style/EstiloModuloTexto" android:text="Historial\nProfesional" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMeritosFormacion"
                style="@style/EstiloModuloCard">
                <TextView style="@style/EstiloModuloTexto" android:text="Méritos y\nFormación" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardRegistrosAdmin"
                style="@style/EstiloModuloCard">
                <TextView style="@style/EstiloModuloTexto" android:text="Otros\nRegistros" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardExportar"
                style="@style/EstiloModuloCard">
                <TextView style="@style/EstiloModuloTexto" android:text="Exportar\nExpediente" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardActividad"
                style="@style/EstiloModuloCard">
                <TextView style="@style/EstiloModuloTexto" android:text="Actividad\nAPP" />
            </androidx.cardview.widget.CardView>

        </GridLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>