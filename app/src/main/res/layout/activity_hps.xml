<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gris_fondo_abajo">

    <View
        android:id="@+id/viewHeaderHps"
        style="@style/EstiloCabeceraAzul"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnVolverHps"
        style="@style/EstiloBotonVolver"
        android:contentDescription="@string/volver"
        android:src="@drawable/abc_ic_ab_back_material"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTituloHps"
        style="@style/EstiloTituloPantalla"
        android:text="@string/hps_pantalla"
        app:layout_constraintBottom_toBottomOf="@+id/btnVolverHps"
        app:layout_constraintStart_toEndOf="@+id/btnVolverHps"
        app:layout_constraintTop_toTopOf="@+id/btnVolverHps" />

    <LinearLayout
        android:id="@+id/layoutFormularioInferiorHps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@color/blanco_insercion"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/nombre_habilitacion"
            app:boxStrokeColor="@color/bbva_blue">

            <AutoCompleteTextView
                android:id="@+id/etNombreHps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"
                tools:ignore="LabelFor,SpeakableTextPresentCheck" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:hint="@string/fecha_concesion"
                app:boxStrokeColor="@color/bbva_blue">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFechaConcesionHps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="date"
                    android:focusable="false"
                    android:cursorVisible="false"
                    tools:ignore="TextContrastCheck" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:hint="@string/fecha_caducidad"
                app:boxStrokeColor="@color/bbva_blue">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFechaCaducidadHps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="date"
                    android:focusable="false"
                    android:cursorVisible="false"
                    tools:ignore="TextContrastCheck" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAnadirHps"
                style="@style/EstiloBotonAnadir"
                android:text="@string/anadir" />

            <Button
                android:id="@+id/btnModificarHps"
                style="@style/EstiloBotonEditar"
                android:text="@string/editar" />

            <Button
                android:id="@+id/btnEliminarHps"
                style="@style/EstiloBotonBorrar"
                android:text="@string/borrar" />

            <Button
                android:id="@+id/btnLimpiarHps"
                style="@style/EstiloBotonLimpiar"
                android:text="@string/limpiar" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTituloListaHps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/historial_hps_guardadas"
        android:textColor="@color/bbva_blue"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/viewHeaderHps" />

    <LinearLayout
        android:id="@+id/layoutTitulosColumnasHps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        android:orientation="horizontal"
        android:baselineAligned="false"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloListaHps">

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="2"
            android:text="@string/nombre_habilitacion"/>

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="1"
            android:text="@string/fecha_concesion"/>

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="1"
            android:text="@string/fecha_caducidad"
            android:textAlignment="viewEnd"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHps"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutTitulosColumnasHps"
        app:layout_constraintBottom_toTopOf="@+id/layoutFormularioInferiorHps"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:listitem="@layout/item_hps" />

</androidx.constraintlayout.widget.ConstraintLayout>