<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gris_fondo_abajo">

    <View
        android:id="@+id/viewHeaderRelaciones"
        style="@style/EstiloCabeceraAzul"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnVolverRelaciones"
        style="@style/EstiloBotonVolver"
        android:contentDescription="@string/volver"
        android:src="@drawable/abc_ic_ab_back_material"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTituloRelaciones"
        style="@style/EstiloTituloPantalla"
        android:text="@string/relacion"
        app:layout_constraintBottom_toBottomOf="@+id/btnVolverRelaciones"
        app:layout_constraintStart_toEndOf="@+id/btnVolverRelaciones"
        app:layout_constraintTop_toTopOf="@+id/btnVolverRelaciones" />

    <LinearLayout
        android:id="@+id/layoutFormularioInferiorRelaciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@color/blanco_insercion"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/nombre_de_la_relacion"
            app:boxStrokeColor="@color/bbva_blue">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNombreRelacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:hint="@string/fecha_bod_dd_mm_aaaa"
                app:boxStrokeColor="@color/bbva_blue">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFechaBodRelacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="date" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:hint="@string/n_bod"
                app:boxStrokeColor="@color/bbva_blue">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNumBodRelacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAnadirRelacion"
                style="@style/EstiloBotonAnadir"
                android:text="@string/anadir" />

            <Button
                android:id="@+id/btnModificarRelacion"
                style="@style/EstiloBotonEditar"
                android:text="@string/editar" />

            <Button
                android:id="@+id/btnEliminarRelacion"
                style="@style/EstiloBotonBorrar"
                android:text="@string/borrar" />

            <Button
                android:id="@+id/btnLimpiarRelacion"
                style="@style/EstiloBotonLimpiar"
                android:text="@string/limpiar" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTituloListaRelaciones"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/historial_de_relaciones_guardadas"
        android:textColor="@color/bbva_blue"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/viewHeaderRelaciones" />

    <LinearLayout
        android:id="@+id/layoutTitulosColumnasRelaciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloListaRelaciones">

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="0.5"
            android:text="@string/nº"/>

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="2"
            android:text="@string/nombre_relacion"/>

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="1.2"
            android:text="@string/fecha_bod"/>

        <TextView
            style="@style/EstiloTextoColumna"
            android:layout_weight="1"
            android:text="@string/n_bod"
            android:textAlignment="viewEnd"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRelaciones"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutTitulosColumnasRelaciones"
        app:layout_constraintBottom_toTopOf="@+id/layoutFormularioInferiorRelaciones"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:listitem="@layout/item_relacion_admin" />

</androidx.constraintlayout.widget.ConstraintLayout>